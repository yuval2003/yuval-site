---
/**
 * Offerings (C2 — "מה אני מציע") — sits between the Hero and the home-page bio
 * (spec §2). Three vertical blocks, each a subheading + body paragraph layered
 * over a large brass watermark digit (1 / 2 / 3) at ~18% opacity. No icons.
 *
 * The digit is purely decorative: it is aria-hidden + select-none, and the
 * literal "נקודה N" wording is never rendered (spec §2 CRITICAL) — only the
 * subheadings and body copy below are real text. The watermark is anchored to
 * the inline-START (the right edge under RTL) and sits BEHIND the subheading +
 * start of the body (nudged up just a third of its own height), so it reads as
 * a background mark anchoring each block — not a detached digit floating in the
 * margin. Content sits in a relatively positioned layer above it.
 */
const offerings = [
  {
    digit: "1",
    title: "אצלכם בסלון",
    body: "אני מגיע אליכם לשיעור פרטי של 60 דקות, באזור בקעת אונו והמרכז. בלי לבזבז זמן על פקקים וחיפושי חניה — פשוט מוציאים את הגיטרה ומתחילים.",
  },
  {
    digit: "2",
    title: "אחד על אחד, לאורך כל הדרך",
    body: "אתם לא לבד בתהליך. אני קשוב לכם, מזהה מה עוצר אתכם, ומכוון את העבודה בדיוק לשם — כך שכל שיעור מקדם אתכם באמת.",
  },
  {
    digit: "3",
    title: "מפרקים את המורכב",
    body: "ברגע שמפרקים קטע לחלקים קטנים ועובדים על כל חלק בנפרד, הדברים שחשבתם שאינם בהישג ידכם הופכים לטבעיים. זו הדרך שבה אני לומד בעצמי, וזו הדרך שאני מלמד אחרים.",
  },
];
---

<section class="mx-auto max-w-5xl px-6 py-16 lg:py-24" aria-labelledby="offerings-title">
  <h2 id="offerings-title" class="mb-12 lg:mb-16">מה אני מציע</h2>

  <div class="flex flex-col gap-14 lg:gap-20">
    {
      offerings.map((o) => (
        <div class="relative">
          {/* Decorative watermark digit — behind the block, never read aloud
              and never the literal "נקודה N" wording (spec §2). */}
          <span
            aria-hidden="true"
            class="pointer-events-none absolute start-0 top-0 -translate-y-1/3 select-none font-heading text-[6.5rem] font-extrabold leading-none text-brass opacity-[0.18] md:text-[9rem]"
          >
            {o.digit}
          </span>

          <div class="relative">
            <h3 class="m-0">{o.title}</h3>
            <p class="prose-measure m-0 mt-3">{o.body}</p>
          </div>
        </div>
      ))
    }
  </div>
</section>
