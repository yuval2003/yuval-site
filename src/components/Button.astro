---
/**
 * Button — the shared link-button primitive (redesign-v2.md §6). Renders an
 * <a> with two variants so the accent color carries a real hierarchy:
 *
 *  - solid (default): bg-accent + white label. Reserved for the single primary
 *    action on a surface — the phone CTA (התקשרו).
 *  - ghost: transparent with a 1.5px --ink border and --ink label; fills --wood
 *    with a white label on hover. Used for the secondary action (וואטסאפ).
 *
 * Square corners and the px-8/py-4 sizing come from the existing tokens; the
 * label weight is Heebo 600 (font-semibold), matching the §1 button/label row.
 */
interface Props {
  href: string;
  variant?: "solid" | "ghost";
  /** Ghost-only: "light" recolors the outline for dark surfaces (e.g. the hero
   *  scrim) — paper border/label that fills paper on hover. Default "dark". */
  tone?: "dark" | "light";
  ariaLabel?: string;
  class?: string;
}
const {
  href,
  variant = "solid",
  tone = "dark",
  ariaLabel,
  class: className,
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 px-8 py-4 font-semibold no-underline transition-colors";

const ghost =
  tone === "light"
    ? "border-[1.5px] border-bg bg-transparent text-bg hover:bg-bg hover:text-wood"
    : "border-[1.5px] border-text bg-transparent text-text hover:border-wood hover:bg-wood hover:text-white";

const variants = {
  solid: "bg-accent text-white hover:bg-accent-hover",
  ghost,
};
---

<a href={href} aria-label={ariaLabel} class:list={[base, variants[variant], className]}>
  <slot />
</a>
