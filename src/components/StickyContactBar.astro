---
/**
 * StickyContactBar — persistent bottom bar on mobile only, with phone +
 * WhatsApp icon buttons and a small dismiss (X). Mounted site-wide from
 * BaseLayout (PLAN.md §2.6, §3, decision §8.9).
 *
 * Progressive enhancement: the two contact links are plain anchors and work
 * with no JS. Only the dismiss uses a tiny inline script; with JS off the X is
 * simply inert and the bar stays — the core action is never blocked.
 *
 * Hidden from `md` up (desktop has the Footer + Hero CTAs). Sits above content
 * via a fixed position; pages don't need extra bottom padding because the bar
 * is short and the footer already carries generous space below the fold.
 */
import PhoneIcon from "./icons/PhoneIcon.astro";
import WhatsAppIcon from "./icons/WhatsAppIcon.astro";
import { phoneDisplay, phoneHref, whatsappHref } from "../lib/contact";

const item =
  "flex flex-1 items-center justify-center gap-2 py-4 font-semibold text-white no-underline";
---

<div
  id="sticky-contact-bar"
  class="fixed inset-x-0 bottom-0 z-50 flex border-t border-border bg-accent pb-[env(safe-area-inset-bottom)] md:hidden"
  role="region"
  aria-label="צרו קשר מהיר"
>
  <a href={phoneHref} class={item} aria-label={`התקשרו: ${phoneDisplay}`}>
    <PhoneIcon />
    התקשרו
  </a>

  <span class="w-px self-stretch bg-white/30" aria-hidden="true"></span>

  <a href={whatsappHref} class={item} aria-label="שלחו הודעה בוואטסאפ">
    <WhatsAppIcon />
    וואטסאפ
  </a>

  <button
    type="button"
    id="sticky-contact-dismiss"
    class="flex items-center justify-center border-r border-white/30 px-4 text-white"
    aria-label="סגירת סרגל יצירת הקשר"
  >
    <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path
        d="M6 6l12 12M18 6L6 18"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"></path>
    </svg>
  </button>
</div>

<script>
  // Minimal, non-essential enhancement: dismiss the bar for the session. The
  // contact links above work with no JS; this only hides the bar on tap.
  const bar = document.getElementById("sticky-contact-bar");
  const dismiss = document.getElementById("sticky-contact-dismiss");
  dismiss?.addEventListener("click", () => bar?.remove());
</script>
