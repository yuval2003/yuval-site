---
/**
 * BioBlock — prose container with the correct Hebrew measure (~60ch) and the
 * generous body line-height from the base styles. Used by the homepage short
 * bio and (later) the /about long bio (PLAN.md §3). Takes a slot.
 */
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<div class:list={["prose-measure flex flex-col gap-4", className]}>
  <slot />
</div>
