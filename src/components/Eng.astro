---
/**
 * Eng — bidi-isolation wrapper for inline Latin/English text inside RTL flow
 * (names like "Frank Ruhl Libre", future song titles, Latin digit strings such
 * as the phone number).
 *
 * Per PLAN.md §3: this is a real <bdi> element, NOT just a utility class. The
 * element type matters for screen-reader announcement and copy-paste behavior;
 * `unicode-bidi: isolate` (applied via the .eng class) on its own is not enough.
 *
 * `dir` defaults to "ltr" so left-to-right strings (names, formatted numbers)
 * render correctly; pass dir="auto" to let the browser infer per content.
 */
interface Props {
  dir?: "ltr" | "rtl" | "auto";
  class?: string;
}

const { dir = "ltr", class: className } = Astro.props;
---

<bdi dir={dir} class:list={["eng", className]}><slot /></bdi>
