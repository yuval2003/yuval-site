---
/**
 * PhoneIcon — the shared inline phone SVG. Extracted from Footer so CTAButtons,
 * StickyContactBar and Footer all render the same glyph (PLAN.md §4: two inline
 * SVGs only, no icon library, no JS).
 *
 * Decorative by default (aria-hidden) — the surrounding link/button carries the
 * accessible label. Sizing comes from the `class` prop (e.g. "h-5 w-5").
 */
interface Props {
  class?: string;
}
const { class: className = "h-5 w-5" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 24 24"
  fill="currentColor"
  aria-hidden="true"
>
  <path
    d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.24.2 2.45.57 3.57a1 1 0 0 1-.24 1.02l-2.21 2.2Z"
  ></path>
</svg>
