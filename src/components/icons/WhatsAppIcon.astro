---
/**
 * WhatsAppIcon — the shared inline WhatsApp SVG. Extracted from Footer so
 * CTAButtons, StickyContactBar and Footer all render the same glyph (PLAN.md
 * §4: two inline SVGs only, no icon library, no JS).
 *
 * Decorative by default (aria-hidden) — the surrounding link/button carries the
 * accessible label. Sizing comes from the `class` prop (e.g. "h-5 w-5").
 */
interface Props {
  class?: string;
}
const { class: className = "h-5 w-5" } = Astro.props;
