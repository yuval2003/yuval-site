---
/**
 * Hero — split-screen (redesign-v2.md §3, step-6 v2). The portrait photo
 * (2316×3088, 3:4) has critical content top (the Magritte "Lovers" print),
 * middle (Yuval), and bottom (the guitar), so the earlier full-bleed-with-scrim
 * pattern — which needs a landscape crop — was abandoned for two clean columns.
 *
 * Desktop (md+): grid-cols-2, full-bleed (the <section> has no max-width).
 *   - Photo on the LEFT (inline-end, RTL) — order-2.
 *   - Text on the RIGHT (inline-start, RTL) on --wood — order-1 — tagline +
 *     brass hairline + tone="light" CTAs, vertically centered.
 *   - No scrim, no overlap; the columns meet at a clean edge.
 * Mobile (<md): photo on top (so you see who's teaching before the pitch),
 *   text below on --wood.
 *
 * The photo is capped with object-fit: cover + object-position biased to the
 * subject's face/torso, so the natural 3:4 height doesn't blow the hero out.
 */
import CTAButtons from "./CTAButtons.astro";

const tagline = "שיעורי גיטרה — דרך פשוטה ללמוד דברים מורכבים";
---

<section class="hero grid grid-cols-1 md:grid-cols-2">
  <!-- Photo — top on mobile, inline-end (left) on desktop -->
  <div class="hero__photo order-1 md:order-2">
    <img
      src="/images/hero.jpg"
      alt="יובל צרלין מנגן גיטרה קלאסית"
      width="1500"
      height="2000"
      fetchpriority="high"
      class="hero__img"
    />
  </div>

  <!-- Text — below on mobile, inline-start (right) on desktop -->
  <div class="hero__text order-2 flex items-center bg-wood md:order-1">
    <div class="mx-auto w-full max-w-xl px-6 py-16 md:px-12 md:py-20">
      <h1 class="hero__tagline">{tagline}</h1>
      <div class="hero__rule" aria-hidden="true"></div>
      <CTAButtons align="start" tone="light" class="mt-8" />
    </div>
  </div>
</section>

<style>
  /* Desktop: fix the hero height so both columns share it; the photo covers its
     half and the text centres in the other. Mobile: height is the photo cap +
     the text's natural height (section stays auto). */
  @media (min-width: 768px) {
    .hero {
      block-size: clamp(560px, 82vh, 780px);
      /* Pin the single row to the hero height. Without this the row auto-sizes
         to the image's intrinsic 3:4 height (~853px > the column), so the photo
         overflowed the hero and the bio's first line rendered on top of it. */
      grid-template-rows: minmax(0, 1fr);
    }
  }

  .hero__photo {
    position: relative; /* containing block for the absolutely-filled image */
    overflow: hidden; /* clip the cover crop to the column — no spill */
    min-block-size: 0; /* let the grid item shrink to the row, not the image */
    /* Mobile: cap the photo so it leads without pushing the pitch off-screen.
       Desktop: stretch to the grid row height. */
    block-size: 68vh;
  }
  @media (min-width: 768px) {
    .hero__photo {
      block-size: auto;
    }
  }

  /* Absolutely fill the column: out of flow, so the image can never inflate the
     grid row, and object-fit: cover crops it to the column box. */
  .hero__img {
    position: absolute;
    inset: 0;
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    /* Keep the subject's face/torso in frame; trims a little wall above the
       print and a little of the guitar's lower bout, never the core subject. */
    object-position: 50% 42%;
  }

  .hero__tagline {
    max-inline-size: 20ch;
    font-size: clamp(2.25rem, 5vw, 3.25rem);
    line-height: 1.1;
    color: var(--bg);
    text-wrap: balance;
  }

  .hero__rule {
    margin-block-start: var(--space-6);
    inline-size: 4rem;
    block-size: 2px;
    background-color: var(--brass);
  }
</style>
