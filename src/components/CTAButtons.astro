---
/**
 * CTAButtons — the primary contact action: a solid WhatsApp CTA (וואטסאפ)
 * paired with a ghost phone action (התקשרו), with the plain-text number beneath.
 * Used by the Hero and /contact (redesign-v2.md §6; spec C3).
 *
 * Button hierarchy: WhatsApp is the single solid (accent) button — the visually
 * dominant action; the phone action is the ghost variant — see Button.astro.
 * Layout is stacked on mobile, horizontal from `sm` up. Icons come from the
 * shared inline SVGs; contact data from src/lib/contact.ts.
 */
import Button from "./Button.astro";
import PhoneIcon from "./icons/PhoneIcon.astro";
import WhatsAppIcon from "./icons/WhatsAppIcon.astro";
import Eng from "./Eng.astro";
import { phoneDisplay, phoneHref, whatsappHref } from "../lib/contact";

interface Props {
  /** Horizontal alignment of the button row + number. Default centered. */
  align?: "center" | "start";
  /** "light" recolors the ghost button + number for dark surfaces (the hero). */
  tone?: "dark" | "light";
  class?: string;
}
const { align = "center", tone = "dark", class: className } = Astro.props;

const itemsAlign = align === "center" ? "items-center" : "items-start";
const rowJustify = align === "center" ? "sm:justify-center" : "sm:justify-start";
const numberColor = tone === "light" ? "text-bg/75" : "text-text-muted";
---

<div class:list={["flex flex-col gap-3", itemsAlign, className]}>
  <div
    class:list={[
      "flex w-full flex-col items-stretch gap-4 sm:flex-row",
      rowJustify,
    ]}
  >
    <Button href={whatsappHref} variant="solid" ariaLabel="שלחו הודעה בוואטסאפ">
      <WhatsAppIcon />
      וואטסאפ
    </Button>

    <Button
      href={phoneHref}
      variant="ghost"
      tone={tone}
      ariaLabel={`התקשרו: ${phoneDisplay}`}
    >
      <PhoneIcon />
      התקשרו
    </Button>
  </div>

  <p class:list={["m-0 text-small", numberColor]}>
    <Eng>{phoneDisplay}</Eng>
  </p>
</div>
