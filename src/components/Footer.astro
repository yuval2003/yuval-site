---
/**
 * Footer — site-wide closing contact, text-only (redesign-v2.md §6). The big
 * phone+WhatsApp button pair was removed so the accent CTA isn't repeated twice
 * per page; the footer now carries just the phone number (as a tel: link) and
 * the location line. Contact data still comes from src/lib/contact.ts — the
 * same source CTAButtons and StickyContactBar use, so it can never drift.
 */
import Eng from "./Eng.astro";
import { phoneDisplay, phoneHref, locationLine } from "../lib/contact";
---

<footer class="mt-24 border-t border-border">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center gap-2 px-6 py-16 text-center"
  >
    <p class="m-0 text-small text-text-muted">
      מעדיפים להתקשר?
      <a href={phoneHref} class="font-semibold" aria-label={`התקשרו: ${phoneDisplay}`}>
        <Eng>{phoneDisplay}</Eng>
      </a>
    </p>

    <p class="m-0 text-small text-text-muted">
      {locationLine}
    </p>
  </div>
</footer>
