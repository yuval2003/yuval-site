---
/**
 * Nav — site name + the three primary links, in a real <nav> landmark.
 *
 * RTL: the brand sits at the inline-start (right) edge, links at inline-end
 * (left); items read right-to-left naturally under dir="rtl".
 *
 * No JS: the links are always rendered and visible. On narrow screens the row
 * wraps instead of collapsing into a JS-only menu, so navigation is fully
 * keyboard-operable with no script (PLAN.md §7).
 */
const links = [
  { href: "/", label: "דף הבית" },
  { href: "/about", label: "עליי" },
  { href: "/contact", label: "צרו קשר" },
];

const path = Astro.url.pathname.replace(/\/$/, "") || "/";
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(`${href}/`);
---

<nav aria-label="ניווט ראשי" class="border-b border-border bg-bg">
  <div
    class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-x-6 gap-y-3 px-6 py-4"
  >
    <a
      href="/"
      class="font-heading text-2xl font-medium text-text no-underline hover:text-accent"
    >
      יובל צרלין
    </a>

    <ul class="m-0 flex list-none flex-wrap items-center gap-6 p-0">
      {
        links.map((link) => (
          <li>
            <a
              href={link.href}
              aria-current={isActive(link.href) ? "page" : undefined}
              class="text-text no-underline hover:text-accent aria-[current=page]:font-semibold aria-[current=page]:text-accent aria-[current=page]:underline"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>
