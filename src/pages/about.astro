---
/**
 * /about (עליי) — the long-bio page (redesign-v2.md §4): h1 → bio + photo as a
 * two-column band (stacks on mobile) → הגישה שלי → שיעורים → בהמשך → inline CTA.
 * Prose blocks are centered (mx-auto max-w-3xl) so they no longer hug the
 * inline-start edge. Nav, Footer and the mobile StickyContactBar come from
 * BaseLayout.
 *
 * The pull-quote treatment of "מסובך / מורכב" is step 5; for now it keeps the
 * existing inline <em> emphasis inside הגישה שלי. The secondary photo is a
 * clearly-labeled placeholder (public/images/about.jpg) until the real "Yuval
 * by window" photo replaces it before launch (PLAN.md §4).
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import BioBlock from "../components/BioBlock.astro";
---

<BaseLayout title="עליי">
  <!-- Page heading + long bio / photo — two-column band at md+, stacked on
       mobile (bio on the inline-start, photo on the inline-end under RTL). -->
  <section class="mx-auto max-w-5xl px-6 py-16 lg:py-24">
    <h1 class="mb-10">עליי</h1>

    <!-- Asymmetric band (redesign-v2.md §4): the bio takes the wider column and
         the photo the narrower one, both top-aligned. Narrowing the photo column
         lowers the portrait's height so the two columns end closer together,
         instead of a tall photo leaving a vertical void beside a short bio. -->
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr] md:items-start md:gap-12">
      <BioBlock>
        <p class="m-0">אני יובל צרלין, בן 23, מנגן גיטרה כבר 13 שנה.</p>
        <p class="m-0">
          במשך שש שנים ניגנתי בעיקר רוק — סולואים, השירים הגדולים של שנות ה-70,
          ה-80 וה-90, הכל עם מורים פרטיים. עד שהבנתי שמה שאני באמת רוצה לעשות הוא
          דבר אחד: פינגרסטייל. מאז אני מקדיש את הזמן שלי לעיבודים של שירים בעברית
          ובאנגלית, וכותב עיבודים משלי לשירים שאני אוהב.
        </p>
      </BioBlock>

      <img
        src="/images/about.jpg"
        alt="יובל צרלין מנגן גיטרה קלאסית בחצר, על רקע ציור קיר ותאורת שרשרת"
        width="1500"
        height="2000"
        loading="lazy"
        class="mx-auto block w-full max-w-[16rem] border border-border object-cover object-[center_60%] md:mx-0 md:max-w-none"
      />
    </div>
  </section>

  <!-- Pull-quote (redesign-v2.md §5) — the thesis line lifted out of הגישה שלי
       into a full-bleed --wood band; מסובך / מורכב carry the contrast in --brass.
       It is full-bleed because the <section> itself takes no max-width (so its
       background spans the viewport); only the inner div is constrained. -->
  <section class="bg-wood">
    <div class="mx-auto max-w-4xl px-6 py-14 text-center md:py-24">
      <p
        class="m-0 text-[1.875rem] font-bold leading-[1.25] tracking-[-0.005em] text-bg md:text-[2.5rem]"
      >
        זה לא <em class="not-italic text-brass">מסובך</em>, זה רק
        <em class="not-italic text-brass">מורכב</em>. בואו נפרק את זה.
      </p>
    </div>
  </section>

  <!-- הגישה שלי — sidenote grid (§4 corrected): the heading sits in the
       inline-START (right) 1fr column, hugging the outer page margin; the prose
       takes the 3fr column. Stacks to a single column (heading above) below md. -->
  <section class="mx-auto max-w-5xl px-6 py-16 lg:py-24">
    <div class="grid gap-y-3 md:grid-cols-[1fr_3fr] md:gap-x-16 md:gap-y-0">
      <h2 class="m-0">הגישה שלי</h2>
      <BioBlock>
        <p class="m-0">
          ברגע שמפרקים קטע לחלקים קטנים ועובדים על כל חלק בנפרד, הדברים שחשבת
          שאינם בהישג ידך הופכים לטבעיים. זו הדרך שבה אני לומד בעצמי, וזו הדרך
          שאני מלמד אחרים.
        </p>
      </BioBlock>
    </div>
  </section>

  <!-- שיעורים — sidenote grid -->
  <section class="mx-auto max-w-5xl px-6 pb-16 lg:pb-24">
    <div class="grid gap-y-3 md:grid-cols-[1fr_3fr] md:gap-x-16 md:gap-y-0">
      <h2 class="m-0">שיעורים</h2>
      <BioBlock>
        <p class="m-0">
          אני מלמד מתחילים ואנשים שרוצים להגיע במהירות לרמה שמרשימה חברים ובני
          משפחה — לא בעוד שנה, בעוד כמה שיעורים. השיעורים מתקיימים פרונטלית בלבד,
          אצלכם בבית, באזור בקעת אונו והמרכז.
        </p>
      </BioBlock>
    </div>
  </section>

  <!-- בהמשך — sidenote grid -->
  <section class="mx-auto max-w-5xl px-6 pb-16 lg:pb-24">
    <div class="grid gap-y-3 md:grid-cols-[1fr_3fr] md:gap-x-16 md:gap-y-0">
      <h2 class="m-0">בהמשך</h2>
      <BioBlock>
        <p class="m-0">מאגר טאבים ועיבודים שלי לרכישה.</p>
      </BioBlock>
    </div>
  </section>

  <!-- Inline CTA — a single sentence linking to /contact, plain text (not a
       button). Placed in the 3fr column (md:col-start-2) so it follows the
       sidenote prose flow rather than hugging the heading margin (PLAN.md §2.8). -->
  <section class="mx-auto max-w-5xl px-6 pb-16 lg:pb-24">
    <div class="grid md:grid-cols-[1fr_3fr] md:gap-x-16">
      <div class="prose-measure md:col-start-2">
        <p class="m-0">
          רוצים להתחיל? <a href="/contact">צרו קשר ונקבע שיעור</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
