---
/**
 * /contact (צור קשר) — the direct-contact page (redesign-v2.md §4): h1 → a
 * two-column band at md+ with a reassurance panel (3 short lines + the phone /
 * WhatsApp CTAs) alongside the ContactForm. On mobile the two stack with the
 * reassurance panel above the form. Nav, Footer and the mobile StickyContactBar
 * come from BaseLayout; the location line is also carried by the site-wide
 * Footer.
 *
 * The phone/WhatsApp CTAs that used to sit alone above the form now live inside
 * the reassurance panel, so the page leads with the form + the reasons to reach
 * out side by side instead of a lopsided single column.
 */
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButtons from "../components/CTAButtons.astro";
import ContactForm from "../components/ContactForm.astro";
---

<BaseLayout title="צור קשר">
  <section class="mx-auto max-w-5xl px-6 py-16 lg:py-24">
    <h1 class="mb-10">מוכנים להתחיל לנגן?</h1>

    <div class="grid gap-10 md:grid-cols-2 md:items-stretch md:gap-12">
      <!-- Reassurance panel — first in the DOM so it sits above the form on
           mobile; on md+ it stretches to the form's height (items-stretch on the
           grid). justify-start flows the blocks from the top; the "first call"
           mini-section between the lines and the CTAs gives the column enough
           real content that it reads as full rather than padded (step 4.5 v2). -->
      <aside class="flex flex-col justify-start gap-8" aria-label="פרטים ליצירת קשר">
        <ul class="m-0 flex list-none flex-col gap-3 p-0 text-text">
          <li>תשאירו פרטים ואני חוזר אליכם עוד היום.</li>
          <li>השיעורים מתקיימים אצלכם בבית, באזור בקעת אונו והמרכז.</li>
          <li>אף פעם לא החזקתם גיטרה? מתחילים מאפס? הגעתם בדיוק למקום הנכון.</li>
        </ul>

        <!-- What to expect on the first call — a small labelled side note, kept
             visually subordinate to the page h2s: a text-small label with a thin
             brass underline, NOT a heading weight, so it reads as a panel label. -->
        <div class="flex flex-col gap-3">
          <p class="m-0 self-start border-b border-brass pb-1 text-small font-semibold tracking-wide text-text-muted">
            מה קורה בשיחה הראשונה שלנו?
          </p>
          <ul class="m-0 flex list-none flex-col gap-3 p-0 text-text">
            <li>נכיר – מאיפה אתם מגיעים ולאן בא לכם להגיע עם הגיטרה.</li>
            <li>נבין – איך השיטה שלי עובדת ומה פחות או יותר נעשה בשיעורים הראשונים.</li>
            <li>נתאם – אם תרגישו שזה מתאים, נקבע שיעור.</li>
          </ul>
        </div>

        <!-- Direct contact — hidden on mobile, where the sticky bar already
             surfaces phone/WhatsApp; shown from md up. -->
        <div class="hidden md:block">
          <CTAButtons align="start" />
        </div>
      </aside>

      <!-- Passive contact form — same component as the homepage -->
      <ContactForm />
    </div>
  </section>
</BaseLayout>
