---
/**
 * BaseLayout — the site shell: <html dir="rtl" lang="he">, <head> (fonts, meta,
 * Open Graph), a skip-to-main link, semantic landmarks, and the page-body slot
 * (PLAN.md §3).
 */
import "../styles/global.css";

// Self-hosted Google Fonts. Redesign v2 §1: a single family, Heebo (Oded Ezer),
// for headings and body, with hierarchy carried by weight (400/600/700/800).
// Only the Hebrew + Latin subsets are imported, to protect the <200KB
// page-weight budget. Do not add weights or subsets here without revisiting it.
import "@fontsource/heebo/hebrew-400.css";
import "@fontsource/heebo/latin-400.css";
import "@fontsource/heebo/hebrew-600.css";
import "@fontsource/heebo/latin-600.css";
import "@fontsource/heebo/hebrew-700.css";
import "@fontsource/heebo/latin-700.css";
import "@fontsource/heebo/hebrew-800.css";
import "@fontsource/heebo/latin-800.css";

import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import StickyContactBar from "../components/StickyContactBar.astro";

interface Props {
  title: string;
  description?: string;
}

const siteName = "יובל צרלין";
const {
  title,
  description = "שיעורי גיטרה עם יובל צרלין — דרך פשוטה ללמוד דברים מורכבים. שיעורים פרונטליים באזור המרכז.",
} = Astro.props;

const pageTitle = title === siteName ? title : `${title} · ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html dir="rtl" lang="he">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="he_IL" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
  </head>
  <body>
    <a class="skip-link" href="#main">דלג לתוכן</a>
    <Nav />
    {/* pb-20 reserves room on mobile so the fixed StickyContactBar (~64px)
        never overlaps short pages; the bar is hidden from md up, so no pad. */}
    <main id="main" class="pb-20 md:pb-0">
      <slot />
    </main>
    <Footer />
    {/* Mobile-only, dismissible — appears site-wide (PLAN.md §2.6). */}
    <StickyContactBar />
  </body>
</html>
